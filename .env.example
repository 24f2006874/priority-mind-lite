# Hugging Face API Configuration
# Copy this file to .env and fill in your HF_TOKEN

# Your Hugging Face API token (required for live LLM evaluation)
# Get one at: https://huggingface.co/settings/tokens
# Token should have "Write" permissions
HF_TOKEN=hf_your_token_here

# API Configuration - Use HF Router for Inference
# The router.huggingface.co endpoint provides access to Llama models
API_BASE_URL=https://router.huggingface.co/v1

# Model name with provider suffix (novita provides free inference)
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct:novita

# API timeout in seconds
HF_TIMEOUT_SECONDS=12

# Local validation can run without HF_TOKEN by using:
# python inference.py --mock
# python scripts/validate_submission.py